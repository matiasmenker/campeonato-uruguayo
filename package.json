{
  "name": "campeonato-uruguayo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter db generate",
    "db:migrate": "pnpm --filter db migrate",
    "db:migrate:dev": "pnpm --filter db migrate:dev",
    "db:push": "pnpm --filter db push",
    "db:studio": "pnpm --filter db studio",
    "sync": "pnpm --filter data-sync sync",
    "sync:base": "pnpm --filter data-sync sync:base",
    "sync:countries": "pnpm --filter data-sync sync:countries",
    "sync:types": "pnpm --filter data-sync sync:types",
    "sync:leagues": "pnpm --filter data-sync sync:leagues",
    "sync:venues": "pnpm --filter data-sync sync:venues",
    "sync:seasons": "pnpm --filter data-sync sync:seasons",
    "sync:structure": "pnpm --filter data-sync sync:structure",
    "sync:teams": "pnpm --filter data-sync sync:teams",
    "sync:coaches": "pnpm --filter data-sync sync:coaches",
    "sync:referees": "pnpm --filter data-sync sync:referees",
    "sync:players": "pnpm --filter data-sync sync:players",
    "sync:squad-memberships": "pnpm --filter data-sync sync:squad-memberships",
    "sync:transfers": "pnpm --filter data-sync sync:transfers",
    "sync:sidelined": "pnpm --filter data-sync sync:sidelined",
    "sync:states": "pnpm --filter data-sync sync:states",
    "sync:fixtures": "pnpm --filter data-sync sync:fixtures",
    "sync:standings": "pnpm --filter data-sync sync:standings",
    "sync:fixture-details": "pnpm --filter data-sync sync:fixture-details",
    "sync:daily": "pnpm --filter data-sync sync:daily",
    "sync:live": "pnpm --filter data-sync sync:live",
    "sync:fill-stats": "pnpm --filter data-sync sync:fill-stats",
    "report:fixture-players": "pnpm --filter data-sync report:fixture-players",
    "sync:health": "pnpm --filter data-sync sync:health",
    "sync:reset": "cd packages/db && cp ../../.env .env && pnpm exec prisma db push --force-reset && rm .env && cd ../.. && pnpm db:generate",
    "dev": "pnpm dev:api & pnpm dev:web",
    "dev:api": "PORT=3001 pnpm --filter api dev",
    "build:api": "pnpm db:generate && pnpm --filter api build",
    "start:api": "pnpm --filter api start",
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "start:web": "pnpm --filter web start",
    "evidence:team-details": "pnpm --filter data-sync evidence:team-details"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  }
}
